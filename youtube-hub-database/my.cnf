[mysqld]
character-set-server=utf8mb4
default-time-zone = '+09:00' # Example: JST (Japan Standard Time)
pid-file = /var/run/mysqld/mysqld.pid # This is still a good practice for Docker
lower_case_table_names = 1

[mysql]
default-character-set=utf8mb4

[client]
default-character-set=utf8mb4